{
  "name": "avocado-root",
  "private": true,
  "version": "0.1.0",
  "description": "Terminal session sync library — local, IPC, and Tailscale mesh transports",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesyong-42/avocado.git"
  },
  "homepage": "https://github.com/jamesyong-42/avocado#readme",
  "bugs": {
    "url": "https://github.com/jamesyong-42/avocado/issues"
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "tsc -b --clean && rm -rf packages/*/dist",
    "typecheck": "tsc -b --noEmit && pnpm -C apps/playground typecheck",
    "playground": "pnpm -C apps/playground dev",
    "build:all": "tsc -b && pnpm -C apps/playground run build",
    "docs:dev": "pnpm -C docs dev",
    "docs:build": "pnpm -C docs build"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty",
      "@vibecook/truffle"
    ]
  }
}
