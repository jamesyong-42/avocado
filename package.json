{
  "name": "avocado-root",
  "private": true,
  "version": "0.1.0",
  "description": "Terminal session sync library \u2014 local, IPC, and Tailscale mesh transports",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesyong-42/avocado.git"
  },
  "homepage": "https://jamesyong-42.github.io/avocado/",
  "bugs": {
    "url": "https://github.com/jamesyong-42/avocado/issues"
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "tsc -b --clean && rm -rf packages/*/dist",
    "typecheck": "tsc -b && pnpm -C apps/playground typecheck && pnpm -C apps/ghostty typecheck",
    "test": "pnpm -C packages/sdk test",
    "test:unit": "pnpm -C packages/sdk test:unit",
    "test:integration": "pnpm -C packages/sdk test:integration",
    "playground": "pnpm -C apps/playground dev",
    "ghostty": "pnpm -C apps/ghostty dev",
    "build:all": "tsc -b && pnpm -C apps/playground run build",
    "docs:dev": "python3 -m http.server 5173 --directory docs"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty",
      "@vibecook/truffle"
    ]
  }
}
