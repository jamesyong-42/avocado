{
  "name": "avocado",
  "private": true,
  "version": "0.1.0",
  "description": "Terminal session sync for the web stack — local, IPC, mesh, and WebSocket transports",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "tsc -b --clean && rm -rf packages/*/dist",
    "typecheck": "tsc -b --noEmit",
    "playground": "pnpm -C apps/playground dev",
    "build:all": "tsc -b && pnpm -C apps/playground run build"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty",
      "@vibecook/truffle"
    ]
  }
}
