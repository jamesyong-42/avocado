{
  "name": "@avocado/core",
  "version": "0.1.0",
  "description": "Core PTY session management and terminal service for avocado",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
