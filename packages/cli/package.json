{
  "name": "@vibecook/avocado",
  "version": "0.3.0",
  "description": "Avocado CLI — share terminal sessions across processes, machines, and networks",
  "license": "MIT",
  "author": "James Yong",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesyong-42/avocado.git",
    "directory": "packages/cli"
  },
  "homepage": "https://jamesyong-42.github.io/avocado/",
  "bugs": {
    "url": "https://github.com/jamesyong-42/avocado/issues"
  },
  "keywords": [
    "cli",
    "pty",
    "terminal",
    "session-sync",
    "avocado",
    "tailscale",
    "mesh"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "avo": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/postinstall.mjs",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "scripts/postinstall.mjs"
  ],
  "peerDependencies": {
    "node-pty": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "node-pty": {
      "optional": false
    }
  },
  "devDependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@types/node": "^22.0.0",
    "@vibecook/avocado-sdk": "workspace:*",
    "esbuild": "^0.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
