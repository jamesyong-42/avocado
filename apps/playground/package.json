{
  "name": "@avocado-playground/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron showcase app for avocado — demonstrates cross-device terminal session sync over the truffle mesh",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@avocado/core": "workspace:*",
    "@avocado/node-pty": "workspace:*",
    "@avocado/react": "workspace:*",
    "@avocado/transport-ipc": "workspace:*",
    "@avocado/transport-truffle": "workspace:*",
    "@avocado/types": "workspace:*",
    "@react-three/fiber": "^8.17.0",
    "@react-three/postprocessing": "^2.16.0",
    "@vibecook/truffle": "^0.4.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/headless": "^5.5.0",
    "node-pty": "^1.0.0",
    "postprocessing": "^6.35.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.160.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.2.0",
    "electron-vite": "^3.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  }
}
